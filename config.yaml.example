token_env: CLOUDFLARE_TOKEN
ip_sources:
  - https://ifconfig.me/ip
  - https://api.ipify.org
  - https://checkip.amazonaws.com
  - https://icanhazip.com
  - https://ipinfo.io/ip
zones:
  - zone: domain.tld
    records:
      - name: dns
        type: A
        ttl: 120
        proxied: false
      - name: "@"
        type: A
        ttl: 120
        proxied: false
  - zone: example.com
    records:
      - name: "@"
        type: A
        ttl: 300
        proxied: true
